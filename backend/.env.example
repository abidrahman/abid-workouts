# Firebase Configuration
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# COROS OAuth Configuration
COROS_CLIENT_ID=your_coros_client_id
COROS_CLIENT_SECRET=your_coros_client_secret
COROS_REDIRECT_URI=http://127.0.0.1:5173/auth/callback
# For production, use: https://yourdomain.com/auth/callback

# API Configuration
API_BASE_URL=http://localhost:5001/abid-workouts/us-central1
# For production: https://us-central1-abid-workouts.cloudfunctions.net

# COROS API Endpoints (may need to update based on actual API docs)
COROS_AUTH_URL=https://developer.coros.com/oauth2/authorize
COROS_TOKEN_URL=https://developer.coros.com/oauth2/token
COROS_API_BASE_URL=https://api.developer.coros.com/api

# Strava OAuth Configuration
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_ACCESS_TOKEN=your_initial_access_token
STRAVA_REFRESH_TOKEN=your_refresh_token
STRAVA_REDIRECT_URI=http://127.0.0.1:5173/auth/callback
STRAVA_AUTH_URL=https://www.strava.com/oauth/authorize
STRAVA_TOKEN_URL=https://www.strava.com/oauth/token
STRAVA_API_BASE_URL=https://www.strava.com/api/v3
STRAVA_BACKFILL_START=2026-06-01

# Token Encryption (optional: for extra security)
TOKEN_ENCRYPTION_KEY=your-32-char-encryption-key-here
